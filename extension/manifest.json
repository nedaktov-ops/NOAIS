{
  "manifest_version": 3,
  "name": "__MSG_extension_name__",
  "version": "1.1.2",
  "description": "__MSG_extension_description__",
  "default_locale": "en",
  "key": "",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "__MSG_extension_name__",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "side_panel": {
    "default_path": "sidepanel/why.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "core/heuristics.js",
        "core/storage-keys.js",
        "core/sync-helper.js",
        "core/settings.js",
        "core/adapters/base.js",
        "core/adapters/youtube.js",
        "core/adapters/facebook.js",
        "core/adapters/instagram.js",
        "core/adapters/tiktok.js",
        "content/page-counter.js",
        "content/badge-tooltip.js",
        "content/element-allowlist.js",
        "content/content.js"
      ],
      "css": [
        "styles/adapters.css",
        "content/page-counter.css",
        "content/badge-tooltip.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "options/options.html",
        "options/welcome.html",
        "sidepanel/why.html",
        "_locales/en/messages.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "noais@nedaktov-ops.github.io",
      "strict_min_version": "121.0"
    }
  },
  "commands": {
    "noais-toggle-site": {
      "suggested_key": {
        "default": "Ctrl+Shift+A"
      },
      "description": "__MSG_cmd_toggle_site__"
    }
  }
}
